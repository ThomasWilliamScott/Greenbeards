Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"This", " ", "script", " ", "generates", " ", 
     RowBox[{"Fig", ".", " ", "3"}], "b", " ", "in", " ", "the", " ", "main", 
     " ", "text"}], ",", " ", 
    RowBox[{
    "using", " ", "stability", " ", "criteria", " ", "derived", " ", "in", " ",
      "the", " ", "Supplementary", " ", "Information", " ", "Equations", " ", 
     "5", " ", "and", " ", "6.", " ", "Elsewhere", " ", "we", " ", "verified",
      " ", "that", " ", "these", " ", "analytically", " ", "derived", " ", 
     "stability", " ", "criteria", " ", "accurately", " ", "capture", " ", 
     "the", " ", "equilibria", " ", "of", " ", "our", " ", "full", " ", 
     "population", " ", "genetic", " ", 
     RowBox[{"model", ".", " ", "Our"}], " ", "full", " ", "population", " ", 
     "genetic", " ", "model", " ", "can", " ", "be", " ", "run", " ", "using",
      " ", 
     RowBox[{"our", " ", "'"}], 
     RowBox[{"Run_Model", ".", 
      RowBox[{"m", "'"}]}], " ", "Matlab", " ", 
     RowBox[{"script", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Parameter", " ", "values"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"b", "=", "0.3"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"c", "=", "0.1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"s", "=", "0.05"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"\[Alpha]", "=", "0.2"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Equation", " ", "5", " ", "in", " ", "the", " ", "SI", " ", "solved", " ",
      "for", " ", 
     RowBox[{"F", ".", " ", "This"}], " ", "shows", " ", "when", " ", 
     "candidate", " ", "greenbeards", " ", "are", " ", "stable", " ", 
     "against", " ", "falsebeards"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"F5", "[", "d_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"c", "-", "d"}], ")"}], "/", "b"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Equation", " ", "6", " ", "in", " ", "the", " ", "SI", " ", "solved", " ",
      "for", " ", 
     RowBox[{"F", ".", " ", "This"}], " ", "shows", " ", "when", " ", 
     "candidate", " ", "greenbeards", " ", "are", " ", "stable", " ", 
     "against", " ", "nonbeards"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"F6", "[", "d_", "]"}], ":=", 
     RowBox[{"s", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Alpha]"}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"d", "-", "c", "+", "b", "-", 
         RowBox[{"s", " ", "\[Alpha]"}]}], ")"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"The", " ", "below", " ", "gives", " ", "b"}], "=", 
      RowBox[{"c", "=", 
       RowBox[{"0", " ", "versions"}]}]}], ",", " ", 
     RowBox[{
      RowBox[{"i", ".", "e", ".", " ", "stability"}], " ", "conditions", " ", 
      "in", " ", 
      RowBox[{"the", " ", "'"}], "no", " ", 
      RowBox[{"altruism", "'"}], " ", 
      RowBox[{"scenario", "."}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"F5no", "[", "d_", "]"}], ":=", "0"}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"since", " ", "d"}], ">", 
      RowBox[{
      "0", " ", "gives", " ", "vertical", " ", "line", " ", "at", " ", 
       "d"}]}], "=", "0"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"F6no", "[", "d_", "]"}], ":=", 
     RowBox[{"s", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Alpha]"}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"d", "-", 
         RowBox[{"s", " ", "\[Alpha]"}]}], ")"}]}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"F5", "[", "d", "]"}], ",", 
       RowBox[{"F6", "[", "d", "]"}], ",", 
       RowBox[{"F6no", "[", "d", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"d", ",", 
       RowBox[{"-", "0.1"}], ",", "1"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
